# =============================================================================
# SundayChess environment
# =============================================================================
#
# This app talks to TWO Supabase projects, and they MUST stay separate:
#   * the app's own DATA project (tournaments/players/games/moves)  — UNCHANGED
#   * the Sunday Account AUTH (issuer) project — for host login only (NEW)
#
# Players and joiners never touch auth — they use PIN + resume codes. Only the
# arrangør/host signs in with a Sunday Account.

# -----------------------------------------------------------------------------
# DATA project (existing — do NOT repoint these at the issuer)
# -----------------------------------------------------------------------------
# Build-time inlined public values for the app's data project (Realtime anon).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-DATA-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-DATA-ANON-KEY
# Service-role key for the DATA project — Worker SECRET (never NEXT_PUBLIC_*):
#   npx wrangler secret put SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-DATA-SERVICE-ROLE-KEY

# -----------------------------------------------------------------------------
# Sunday Account AUTH (issuer) project — host login (NEW)
# -----------------------------------------------------------------------------
# These are the SundayInfo / Sunday Account issuer project's PUBLIC values
# (its NEXT_PUBLIC_SUPABASE_URL / _ANON_KEY). The AUTH client owns the shared
# sb-* session cookie; the DATA/anon client above stays session-less so they
# never fight over cookies.
NEXT_PUBLIC_SUNDAY_AUTH_URL=https://YOUR-ISSUER-PROJECT.supabase.co
NEXT_PUBLIC_SUNDAY_AUTH_ANON_KEY=YOUR-ISSUER-ANON-KEY

# Comma/space-separated allow-list of emails permitted to act as a host. A
# signed-in Sunday Account is only treated as an arrangør if its email is here.
# Empty = no Sunday Account host is authorized (fail closed); the code-based host
# flow is unaffected.
CHESS_ADMIN_EMAILS=you@example.com,colleague@example.com

# Cross-subdomain SSO cookie domain — PRODUCTION ONLY. Set to share one Sunday
# Account login across *.sundaysuite.app. LEAVE UNSET in local dev (so cookies
# work on localhost).
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app
